<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ── Base implicit styles ── -->

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource NoteTextColor}, Dark=White}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14,10" />
    </Style>

    <Style TargetType="Editor">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <!-- ── Named styles ── -->

    <!-- Primary (Spotify-green) action button -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource SpotifyGreen}" />
        <Setter Property="TextColor" Value="{StaticResource SpotifyBlack}" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="50" />
        <Setter Property="HeightRequest" Value="48" />
    </Style>

    <!-- Transparent icon button used in the header row -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <!-- Orange skip-seconds button -->
    <Style x:Key="SkipButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource SkipButtonColor}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <!-- Circular play/pause button -->
    <Style x:Key="PlayButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="White" />
        <Setter Property="TextColor" Value="{StaticResource SpotifyGreen}" />
        <Setter Property="CornerRadius" Value="32" />
        <Setter Property="WidthRequest" Value="64" />
        <Setter Property="HeightRequest" Value="64" />
    </Style>

    <!-- Notes editor card -->
    <Style x:Key="NotesEditorCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="White" />
        <Setter Property="StrokeShape" Value="RoundRectangle 10" />
        <Setter Property="Stroke" Value="Transparent" />
    </Style>

</ResourceDictionary>
